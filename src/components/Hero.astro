---
// ── Blackline home hero — full-bleed cinematic band (inspired by the agency
// benchmark): a flagship from the real inventory fills the frame, a moody scrim
// carries the headline, then the page opens into the light content. Static, no
// rented film. LCP = the flagship image. Headline is plain text (CLS/LCP safe).
import { Phone, Star, ArrowRight } from '@lucide/astro';
import { site, contact } from '../data/site';
import { fmtAED, carTitle } from '../lib/cars';
import type { Car } from '../lib/cars';

interface Props { car: Car }
const { car } = Astro.props;
const cover = car.images[0];
const title = carTitle(car);
---
<section class="relative flex min-h-[86svh] flex-col justify-end overflow-hidden bg-night">
  <img src={cover} alt={title} class="absolute inset-0 h-full w-full object-cover object-[68%_45%]" fetchpriority="high" decoding="async" />
  <!-- strong left-anchored scrim (the studio bg is bright, so the dark must carry the text) -->
  <div class="absolute inset-0 bg-gradient-to-r from-[#0c0b09] from-[8%] via-[#0c0b09]/82 via-[42%] to-transparent to-[78%]"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-[#0c0b09]/85 via-transparent to-[#0c0b09]/30"></div>
  <span class="bl-line pointer-events-none absolute inset-x-0 top-1/3 h-28 opacity-40" aria-hidden="true"></span>

  <div class="lux-wide relative z-10 pb-14 pt-[calc(var(--nav-h)+2rem)] lg:pb-20">
    <div class="max-w-2xl">
      <p class="eyebrow text-gilt"><span class="h-px w-7 bg-gilt/70"></span>{site.city} · Premium Pre-Owned</p>
      <h1 class="mt-5 display-1 text-cream" style="text-shadow:0 2px 40px rgb(12 11 9 / 0.5)">
        Sell your premium car.<br /><span class="text-gilt">Buy your next one.</span>
      </h1>
      <p class="mt-6 max-w-lg text-[1.05rem] leading-relaxed text-cream/80">
        Dubai’s boutique dealer for high-spec luxury and performance cars. Top prices, no fees,
        instant payment — and a curated showroom of vehicles worth owning.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="/sell-your-car" class="btn-gold h-[54px] px-7 text-[0.82rem] uppercase tracking-[0.13em]">Get my valuation</a>
        <a href="/our-cars" class="btn-cream h-[54px] px-7 text-[0.82rem] uppercase tracking-[0.13em]">Browse our cars <ArrowRight class="h-4 w-4" /></a>
      </div>
      <div class="mt-9 flex flex-wrap items-center gap-x-7 gap-y-3 border-t border-cream/15 pt-7 text-[0.82rem]">
        <a href={contact.phonePrimaryHref} class="inline-flex items-center gap-2 font-medium text-cream transition-colors hover:text-gilt"><Phone class="h-4 w-4 text-gilt" /> {contact.phonePrimary}</a>
        <span class="inline-flex items-center gap-1.5 text-cream/70">
          <span class="inline-flex text-gilt">{Array.from({ length: 5 }).map(() => <Star class="h-3.5 w-3.5 fill-current" />)}</span>
          {contact.reviewCount}+ reviews · Ras Al Khor
        </span>
      </div>
    </div>
  </div>
</section>
