---
// ── Blackline hero — light, airy split: headline + a framed flagship from the
// real inventory. The studio photos are shot on a light backdrop, so they sit
// natively on the bright page inside a clean white card with a soft shadow.
// Static. LCP = the flagship image. Headline is plain text (CLS/LCP safe).
import { ChevronDown, Phone, Star } from '@lucide/astro';
import { site, contact } from '../data/site';
import { fmtAED, carTitle } from '../lib/cars';
import type { Car } from '../lib/cars';

interface Props { car: Car }
const { car } = Astro.props;
const cover = car.images[0];
const title = carTitle(car);
---
<section class="relative overflow-hidden pt-[var(--nav-h)]"
  style="background:radial-gradient(120% 90% at 78% 8%, rgb(244 241 233) 0%, rgb(250 249 245) 55%)">
  <div class="lux-wide grid items-center gap-10 pb-14 pt-8 lg:grid-cols-[0.94fr_1.06fr] lg:gap-12 lg:pb-24 lg:pt-14">
    <!-- Headline panel -->
    <div class="relative order-2 lg:order-1">
      <p class="eyebrow"><span class="h-px w-7 bg-gold/70"></span>{site.city} · Premium Pre-Owned</p>
      <h1 class="mt-5 display-1 text-ivory">
        Sell your premium car.<br /><span class="text-gold">Buy your next one.</span>
      </h1>
      <p class="mt-6 max-w-md text-[1.05rem] leading-relaxed text-mist">
        Dubai’s boutique dealer for high-spec luxury and performance cars. Top prices, no fees,
        instant payment — and a curated showroom of vehicles worth owning.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="/sell-your-car" class="btn-gold h-[54px] px-7 text-[0.82rem] uppercase tracking-[0.13em]">Get my valuation</a>
        <a href="/our-cars" class="btn-ink h-[54px] px-7 text-[0.82rem] uppercase tracking-[0.13em]">Browse our cars</a>
      </div>
      <div class="mt-9 flex flex-wrap items-center gap-x-7 gap-y-3 border-t border-ivory/[0.08] pt-7 text-[0.82rem]">
        <a href={contact.phonePrimaryHref} class="inline-flex items-center gap-2 font-medium text-ivory transition-colors hover:text-gold"><Phone class="h-4 w-4 text-gold" /> {contact.phonePrimary}</a>
        <span class="inline-flex items-center gap-1.5 text-mist">
          <span class="inline-flex text-gold">{Array.from({ length: 5 }).map(() => <Star class="h-3.5 w-3.5 fill-current" />)}</span>
          {contact.reviewCount}+ reviews · Ras Al Khor
        </span>
      </div>
    </div>

    <!-- Framed flagship -->
    <div class="relative order-1 lg:order-2" data-reveal>
      <div class="relative overflow-hidden rounded-[1.25rem] border border-ivory/[0.08] bg-white shadow-[0_2px_4px_rgb(20_18_15/0.05),0_44px_90px_-40px_rgb(20_18_15/0.4)]">
        <img src={cover} alt={title} width="1280" height="853" fetchpriority="high" decoding="async"
          class="aspect-[3/2] w-full object-cover" />
      </div>
      <!-- floating spec tag — dark, pops against the light photo -->
      <a href={`/our-cars/${car.slug}`} class="group absolute -bottom-4 left-4 inline-flex items-center gap-3 rounded-xl bg-[#16140F] px-4 py-3 shadow-[0_18px_40px_-18px_rgb(20_18_15/0.55)] transition-transform duration-300 hover:-translate-y-0.5 sm:left-6">
        <span class="block">
          <span class="block text-[0.65rem] uppercase tracking-[0.16em] text-cream/55">In the showroom</span>
          <span class="block text-sm font-semibold text-cream">{title}</span>
        </span>
        <span class="price-aed whitespace-nowrap border-l border-cream/15 pl-3 text-sm font-semibold text-gilt">{fmtAED(car.priceAED)}</span>
      </a>
    </div>
  </div>

  <a href="#sell" class="lux-wide relative z-10 hidden pb-7 lg:flex" aria-label="Scroll down">
    <span class="inline-flex items-center gap-2 text-[0.7rem] uppercase tracking-[0.2em] text-faint"><ChevronDown class="h-4 w-4 motion-safe:animate-scrollcue" /> Sell · Buy · Consign</span>
  </a>
</section>
