---
import { ChevronRight, ChevronLeft, Check, ShieldCheck } from '@lucide/astro';
import { makeOptions, yearOptions, kmOptions, specsOptions, contact } from '../data/site';

interface Props {
  preselectMake?: string;   // e.g. "Porsche" — pre-fills + locks step 1 make on sell-my-[brand]
  compact?: boolean;        // tighter padding when embedded in a hero column
  id?: string;
}
const { preselectMake = '', compact = false, id = 'sell' } = Astro.props;
// strip a tel: number to digits for the wa.me link composed client-side
const waNumber = contact.whatsapp.replace(/\D/g, '');
const inputCls = 'w-full rounded-xl border border-ivory/[0.14] bg-[#FAF9F5] px-4 text-ivory placeholder:text-faint focus:border-gold/70 focus:bg-white focus:outline-none focus:ring-0 transition-colors';
const selCls = inputCls + " appearance-none bg-[url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2214%22 height=%2214%22 fill=%22none%22 stroke=%22%235C5851%22 stroke-width=%222%22 viewBox=%220 0 24 24%22><path d=%22M6 9l6 6 6-6%22/></svg>')] bg-[length:14px] bg-[right_1rem_center] bg-no-repeat";
---
<div data-wizard data-wa={waNumber} class:list={['card relative overflow-hidden', compact ? 'p-5 sm:p-7' : 'p-6 sm:p-9']}>
  <!-- signature diagonal line accent (echoes the logo) -->
  <span class="bl-line pointer-events-none absolute -right-10 -top-10 h-40 w-40 rotate-12 opacity-60" aria-hidden="true"></span>

  <!-- Step indicator -->
  <div class="mb-6 flex items-center gap-3">
    <div data-step-dots class="flex items-center gap-2.5 text-[0.7rem] font-medium uppercase tracking-[0.18em]">
      <span data-dot="1" class="flex items-center gap-2 text-gold"><span class="grid h-6 w-6 place-items-center rounded-full border border-gold text-[0.7rem]">1</span> Vehicle</span>
      <span class="h-px w-6 bg-ivory/15"></span>
      <span data-dot="2" class="flex items-center gap-2 text-faint"><span class="grid h-6 w-6 place-items-center rounded-full border border-ivory/20 text-[0.7rem]">2</span> Details</span>
    </div>
  </div>

  <form data-form novalidate>
    <!-- STEP 1 — Vehicle -->
    <div data-panel="1">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div class="sm:col-span-2">
          <label class="mb-1.5 block text-[0.72rem] font-medium uppercase tracking-[0.14em] text-mist" for={`${id}-make`}>Car Make <span class="text-gold">*</span></label>
          <select id={`${id}-make`} name="make" required class={`${selCls} h-[52px]`} disabled={!!preselectMake}>
            <option value="" disabled selected={!preselectMake}>Select Car Make</option>
            {makeOptions.map((m) => <option value={m} selected={preselectMake === m}>{m}</option>)}
          </select>
          {preselectMake && <input type="hidden" name="make" value={preselectMake} />}
        </div>
        <div class="sm:col-span-2">
          <label class="mb-1.5 block text-[0.72rem] font-medium uppercase tracking-[0.14em] text-mist" for={`${id}-model`}>Car Model <span class="text-gold">*</span></label>
          <input id={`${id}-model`} name="model" required placeholder="e.g. 911 Turbo S" class={`${inputCls} h-[52px]`} />
        </div>
        <div>
          <label class="mb-1.5 block text-[0.72rem] font-medium uppercase tracking-[0.14em] text-mist" for={`${id}-year`}>Year <span class="text-gold">*</span></label>
          <select id={`${id}-year`} name="year" required class={`${selCls} h-[52px]`}>
            <option value="" disabled selected>Select Year</option>
            {yearOptions.map((y) => <option value={y}>{y}</option>)}
          </select>
        </div>
        <div>
          <label class="mb-1.5 block text-[0.72rem] font-medium uppercase tracking-[0.14em] text-mist" for={`${id}-km`}>Kilometers</label>
          <select id={`${id}-km`} name="km" class={`${selCls} h-[52px]`}>
            <option value="" disabled selected>Mileage</option>
            {kmOptions.map((k) => <option value={k}>{k}</option>)}
          </select>
        </div>
        <div class="sm:col-span-2">
          <label class="mb-1.5 block text-[0.72rem] font-medium uppercase tracking-[0.14em] text-mist" for={`${id}-specs`}>Regional Specs <span class="text-gold">*</span></label>
          <select id={`${id}-specs`} name="specs" required class={`${selCls} h-[52px]`}>
            <option value="" disabled selected>Select Regional Specs</option>
            {specsOptions.map((s) => <option value={s}>{s}</option>)}
          </select>
        </div>
      </div>
      <p data-err1 class="mt-3 hidden text-sm text-gold-lite">Please complete the required fields.</p>
      <button type="button" data-next class="btn-gold btn-block mt-6 h-[54px] text-[0.82rem] uppercase tracking-[0.14em]">
        Next <ChevronRight class="h-4 w-4" />
      </button>
    </div>

    <!-- STEP 2 — Details -->
    <div data-panel="2" class="hidden">
      <p class="mb-5 font-display text-lg font-semibold text-ivory">Just a few more details</p>
      <div class="grid grid-cols-1 gap-4">
        <div>
          <label class="mb-1.5 block text-[0.72rem] font-medium uppercase tracking-[0.14em] text-mist" for={`${id}-name`}>Name <span class="text-gold">*</span></label>
          <input id={`${id}-name`} name="name" required autocomplete="name" placeholder="Your name" class={`${inputCls} h-[52px]`} />
        </div>
        <div>
          <label class="mb-1.5 block text-[0.72rem] font-medium uppercase tracking-[0.14em] text-mist" for={`${id}-email`}>Email <span class="text-gold">*</span></label>
          <input id={`${id}-email`} name="email" type="email" required autocomplete="email" placeholder="you@email.com" class={`${inputCls} h-[52px]`} />
        </div>
        <div>
          <label class="mb-1.5 block text-[0.72rem] font-medium uppercase tracking-[0.14em] text-mist" for={`${id}-phone`}>Phone <span class="text-gold">*</span></label>
          <input id={`${id}-phone`} name="phone" type="tel" required autocomplete="tel" placeholder="+971 5x xxx xxxx" class={`${inputCls} h-[52px]`} />
        </div>
      </div>
      <p data-err2 class="mt-3 hidden text-sm text-gold-lite">Please add your name, a valid email and phone.</p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <button type="button" data-back class="btn-outline h-[54px] px-6 text-[0.8rem] uppercase tracking-[0.14em] sm:w-auto"><ChevronLeft class="h-4 w-4" /> Back</button>
        <button type="submit" class="btn-gold h-[54px] flex-1 text-[0.82rem] uppercase tracking-[0.14em]">Get my valuation</button>
      </div>
      <p class="mt-4 flex items-center gap-2 text-[0.72rem] text-faint"><ShieldCheck class="h-3.5 w-3.5" /> Free, no obligation. We never share your details.</p>
    </div>

    <!-- SUCCESS -->
    <div data-panel="done" class="hidden py-6 text-center">
      <span class="mx-auto grid h-14 w-14 place-items-center rounded-full border border-gold/50 text-gold"><Check class="h-7 w-7" /></span>
      <h3 class="mt-5 font-display text-2xl font-semibold text-ivory">Thank you — request received</h3>
      <p class="mx-auto mt-2 max-w-sm text-sm text-mist">One of our valuation specialists will be in touch shortly with your free, no-obligation price.</p>
      <a data-wa-link href={contact.whatsapp} target="_blank" rel="noopener" class="btn-gold mt-6 inline-flex h-[52px] px-7">Continue on WhatsApp now</a>
    </div>
  </form>
</div>

<script>
  document.querySelectorAll('[data-wizard]').forEach((root) => {
    const r = root as HTMLElement;
    const form = r.querySelector('[data-form]') as HTMLFormElement;
    const wa = r.dataset.wa || '';
    const panel = (n: string) => r.querySelector(`[data-panel="${n}"]`) as HTMLElement;
    const show = (n: string) => {
      ['1', '2', 'done'].forEach((k) => panel(k)?.classList.toggle('hidden', k !== n));
      const d1 = r.querySelector('[data-dot="1"]') as HTMLElement;
      const d2 = r.querySelector('[data-dot="2"]') as HTMLElement;
      d1?.classList.toggle('text-gold', n !== '2');
      d1?.classList.toggle('text-faint', n === '2');
      d2?.classList.toggle('text-gold', n === '2');
      d2?.classList.toggle('text-faint', n !== '2');
      r.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    };
    const req = (sel: string) => Array.from(form.querySelectorAll(sel)) as HTMLInputElement[];
    const valid = (els: HTMLInputElement[]) => els.every((el) => {
      const ok = el.value.trim() !== '' && (el.type !== 'email' || /^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(el.value));
      el.classList.toggle('border-gold/70', !ok && el.value.trim() === '' ? false : false);
      el.style.borderColor = ok ? '' : 'rgb(199 169 119 / 0.8)';
      return ok;
    });

    r.querySelector('[data-next]')?.addEventListener('click', () => {
      const els = req('[data-panel="1"] [required]');
      const err = r.querySelector('[data-err1]') as HTMLElement;
      if (!valid(els)) { err.classList.remove('hidden'); return; }
      err.classList.add('hidden'); show('2');
    });
    r.querySelector('[data-back]')?.addEventListener('click', () => show('1'));

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const els = req('[data-panel="2"] [required]');
      const err = r.querySelector('[data-err2]') as HTMLElement;
      if (!valid(els)) { err.classList.remove('hidden'); return; }
      err.classList.add('hidden');
      const fd = new FormData(form);
      const g = (k: string) => String(fd.get(k) || '').trim();
      const msg =
        `Hi Blackline, I'd like a valuation for my car:%0A` +
        `Make: ${g('make')}%0AModel: ${g('model')}%0AYear: ${g('year')}%0A` +
        `Mileage: ${g('km') || 'n/a'}%0ASpecs: ${g('specs')}%0A%0A` +
        `Name: ${g('name')}%0AEmail: ${g('email')}%0APhone: ${g('phone')}`;
      const link = `https://wa.me/${wa}?text=${msg}`;
      const waBtn = r.querySelector('[data-wa-link]') as HTMLAnchorElement;
      if (waBtn) waBtn.href = link;
      show('done');
    });
  });
</script>
