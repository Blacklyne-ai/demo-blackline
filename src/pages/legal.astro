---
import Layout from '../layouts/Layout.astro';
import { contact, site } from '../data/site';
---
<Layout title="Legal notice — Blackline Motor Company" navVariant="solid"
  description="Legal notice for Blackline Motor Company — registered details and how to reach us.">

  <!-- Hero -->
  <section class="bg-ink pt-[calc(var(--nav-h)+2rem)]">
    <div class="lux-narrow pb-12 lg:pb-16">
      <p class="eyebrow"><span class="h-px w-7 bg-gold/70"></span>Legal</p>
      <h1 class="mt-5 display-1 text-ivory">Legal notice</h1>
      <p class="mt-7 text-[1.05rem] leading-relaxed text-mist">
        The company behind the showroom — registered details and how to reach us.
      </p>
    </div>
  </section>

  <!-- Body -->
  <section class="border-t border-ivory/[0.06] bg-coal py-16 lg:py-24">
    <div class="lux-narrow space-y-12">
      <div class="border-t border-ivory/10 pt-12 first:border-0 first:pt-0" data-reveal>
        <h2 class="eyebrow mb-3"><span class="h-px w-7 bg-gold/70"></span>Company</h2>
        <p class="font-display text-[clamp(1.3rem,2.2vw,1.7rem)] font-normal leading-snug text-ivory">{site.legalName}</p>
        <p class="mt-2 text-mist">Premium pre-owned car dealer, {site.city}.</p>
      </div>

      <div class="border-t border-ivory/10 pt-12" data-reveal>
        <h2 class="eyebrow mb-3"><span class="h-px w-7 bg-gold/70"></span>Showroom & registered address</h2>
        <p class="text-[1.02rem] leading-relaxed text-mist">{contact.address}</p>
      </div>

      <div class="border-t border-ivory/10 pt-12" data-reveal>
        <h2 class="eyebrow mb-3"><span class="h-px w-7 bg-gold/70"></span>Contact</h2>
        <p class="text-[1.02rem] leading-relaxed text-mist">
          Phone: <a href={contact.phonePrimaryHref} class="text-gold-deep hover:text-gold">{contact.phonePrimary}</a> · <a href={contact.phoneSecondaryHref} class="text-gold-deep hover:text-gold">{contact.phoneSecondary}</a><br />
          Email: <a href={contact.emailHref} class="text-gold-deep hover:text-gold">{contact.email}</a>
        </p>
      </div>

      <div class="rounded-2xl border border-gold/25 bg-gold/[0.06] p-6 text-sm lg:p-7" data-reveal>
        <p class="leading-relaxed text-mist"><strong class="font-medium text-ivory">Operator-TODO before go-live:</strong> add the UAE Trade Licence number, issuing authority (DED), VAT/TRN and confirm the registered operating entity. Verify all legal disclosures required for a Dubai car dealership.</p>
      </div>
    </div>
  </section>
</Layout>
