---
import Layout from '../../layouts/Layout.astro';
import CarCard from '../../components/CarCard.astro';
import { getCars } from '../../lib/cars';
import { Heart, MessageCircle, ArrowRight } from '@lucide/astro';
import { contact } from '../../data/site';
const cars = await getCars();
---
<Layout title="Saved cars — Blackline Motor Company" description="Your shortlist of saved cars at Blackline Motor Company. Send it to us and we'll confirm availability and the best price.">
  <header class="bg-ink pt-[calc(var(--nav-h)+2rem)]">
    <div class="lux-wide pb-10">
      <p class="eyebrow"><span class="h-px w-7 bg-gold/70"></span>Your shortlist</p>
      <h1 class="mt-5 display-1 text-ivory">Saved cars</h1>
      <p class="mt-5 max-w-xl text-[1.02rem] leading-relaxed text-mist">The cars you’ve saved live here on this device. Send us your shortlist and we’ll confirm availability and the best price.</p>
    </div>
  </header>

  <section class="lux-wide py-12 lg:py-16">
    <!-- MOBILE: one car per row -->
    <div data-wishgrid class="grid grid-cols-1 gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
      {cars.map((car) => (
        <div data-wishitem data-id={car.slug} class="hidden"><CarCard car={car} /></div>
      ))}
    </div>

    <!-- Empty state -->
    <div data-wishempty class="mx-auto max-w-xl py-16 text-center lg:py-24" data-reveal>
      <div class="mx-auto grid h-20 w-20 place-items-center rounded-full border border-gold/25 bg-gold/[0.06] text-gold">
        <Heart class="h-8 w-8" stroke-width={1.3} />
      </div>
      <h2 class="mt-8 display-3 text-ivory">No saved cars — yet.</h2>
      <p class="mx-auto mt-4 max-w-md text-[1rem] leading-relaxed text-mist">Tap the heart on any car as you browse the showroom, and it will be waiting for you here when you’re ready to decide.</p>
      <a href="/our-cars" class="btn-gold mt-9">Browse our cars <ArrowRight class="h-4 w-4" /></a>
    </div>

    <!-- Shortlist CTA -->
    <div data-wishcta class="mt-16 hidden" data-reveal>
      <div class="overflow-hidden rounded-3xl border border-ivory/10 bg-coal">
        <div class="grid items-center gap-8 p-8 sm:p-12 lg:grid-cols-12 lg:gap-12 lg:p-16">
          <div class="lg:col-span-8">
            <p class="eyebrow mb-4">One message away</p>
            <h2 class="display-3 text-ivory">Ready when you are.</h2>
            <p class="mt-4 max-w-xl text-[1rem] leading-relaxed text-mist">Send your shortlist over WhatsApp and we’ll come back with availability, pricing and finance options.</p>
          </div>
          <div class="flex flex-col gap-3 lg:col-span-4">
            <a data-wa href={contact.whatsapp} target="_blank" rel="noopener" class="btn-gold justify-center"><MessageCircle class="h-4 w-4" /> Send shortlist</a>
            <a href="/sell-your-car" class="btn-outline justify-center">Sell or trade-in</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const items = Array.from(document.querySelectorAll('[data-wishitem]')) as HTMLElement[];
  const empty = document.querySelector('[data-wishempty]') as HTMLElement;
  const cta = document.querySelector('[data-wishcta]') as HTMLElement;
  const wa = document.querySelector('[data-wa]') as HTMLAnchorElement;
  const baseWa = (wa?.href || '').split('?')[0];

  function render() {
    let ids: string[] = [];
    try { ids = JSON.parse(localStorage.getItem('bl-wishlist') || '[]'); } catch {}
    let count = 0;
    const names: string[] = [];
    items.forEach((it) => {
      const on = ids.includes(it.dataset.id || '');
      it.classList.toggle('hidden', !on);
      if (on) { count++; const n = it.querySelector('h3')?.textContent?.trim(); if (n) names.push(n); }
    });
    empty.classList.toggle('hidden', count > 0);
    cta.classList.toggle('hidden', count === 0);
    if (wa && count > 0) {
      const txt = encodeURIComponent(`Hi Blackline, I'm interested in these cars: ${names.join(', ')}. Could you confirm availability and pricing?`);
      wa.href = `${baseWa}?text=${txt}`;
    }
  }
  render();
  document.addEventListener('wishlist:change', render);
  window.addEventListener('storage', render);
</script>
