---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import CarCard from '../../components/CarCard.astro';
import { getCars, fmtAED, fmtKm, similar, carTitle, descLines } from '../../lib/cars';
import { contact } from '../../data/site';
import { Heart, Calendar, Gauge, Cog, ShieldCheck, Car as CarIcon, Fuel, Cylinder, Cpu, Palette, ChevronRight, MessageCircle, Phone, Tag, ArrowRight } from '@lucide/astro';

export async function getStaticPaths() {
  const entries = await getCollection('cars');
  return entries.map((e) => ({ params: { slug: e.data.slug }, props: { car: e.data } }));
}
const { car } = Astro.props;
const cars = await getCars();
const sims = similar(cars, car, 3);
const title = carTitle(car);
const { lead, bullets } = descLines(car.description);
const waText = encodeURIComponent(`Hi Blackline, I'm interested in the ${title} (${fmtAED(car.priceAED)}). Is it available?`);

const specRows = [
  { icon: Calendar, label: 'Year', value: String(car.year) },
  { icon: Gauge, label: 'Mileage', value: fmtKm(car.kilometers) },
  { icon: Cog, label: 'Transmission', value: car.transmission },
  car.specs && { icon: ShieldCheck, label: 'Regional specs', value: car.specs },
  car.bodyType && { icon: CarIcon, label: 'Body', value: car.bodyType },
  car.fuel && { icon: Fuel, label: 'Fuel', value: car.fuel },
  car.cylinders && { icon: Cylinder, label: 'Cylinders', value: String(car.cylinders) },
  car.engine && { icon: Cpu, label: 'Engine', value: car.engine },
  car.exteriorColor && { icon: Palette, label: 'Exterior', value: car.exteriorColor },
  car.interiorColor && { icon: Palette, label: 'Interior', value: car.interiorColor },
].filter(Boolean) as { icon: any; label: string; value: string }[];
---
<Layout title={`${title} for sale in Dubai | Blackline Motor Company`} description={`${title} — ${fmtKm(car.kilometers)}, ${car.specs} specs. ${fmtAED(car.priceAED)} at Blackline Motor Company, Ras Al Khor, Dubai.`} image={car.images[0]} navVariant="solid">
  <div class="pt-[calc(var(--nav-h)+1.5rem)]">
    <!-- breadcrumb -->
    <div class="lux-wide">
      <nav class="flex items-center gap-1.5 text-xs text-faint" aria-label="Breadcrumb">
        <a href="/our-cars" class="hover:text-gold">Our cars</a><ChevronRight class="h-3 w-3" />
        <a href={`/our-cars?make=${encodeURIComponent(car.make)}`} class="hover:text-gold">{car.make}</a><ChevronRight class="h-3 w-3" />
        <span class="truncate text-mist">{car.model}</span>
      </nav>
    </div>

    <section class="lux-wide grid gap-10 py-8 lg:grid-cols-[1.15fr_0.85fr] lg:gap-14 lg:py-10">
      <!-- Gallery -->
      <div>
        <div class="relative overflow-hidden rounded-2xl border border-ivory/10 bg-coal">
          <img data-main src={car.images[0]} alt={title} width="1280" height="853" class="aspect-[3/2] w-full object-cover" fetchpriority="high" decoding="async" />
          <button data-wish data-id={car.slug} aria-label={`Save ${title}`} aria-pressed="false"
            class="absolute right-4 top-4 grid h-11 w-11 place-items-center rounded-full bg-[#16140F]/55 text-cream backdrop-blur-sm transition-colors hover:text-gilt">
            <Heart class="h-5 w-5" />
          </button>
        </div>
        {car.images.length > 1 && (
          <div class="mt-3 grid grid-cols-5 gap-3">
            {car.images.slice(0, 10).map((img, i) => (
              <button data-thumb={img} class:list={['overflow-hidden rounded-lg border transition-colors', i === 0 ? 'border-gold/60' : 'border-ivory/10 hover:border-ivory/30']}>
                <img src={img} alt={`${title} photo ${i + 1}`} width="200" height="150" loading="lazy" decoding="async" class="aspect-[4/3] w-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Info -->
      <div class="lg:pt-2">
        <div class="flex items-center gap-2">
          <span class="chip">{car.specs}</span>
          {car.bodyType && <span class="chip">{car.bodyType}</span>}
        </div>
        <h1 class="mt-4 font-display text-[2rem] font-semibold leading-[1.05] text-ivory sm:text-[2.6rem]">{title}</h1>

        <!-- price card -->
        <div class="mt-6 rounded-2xl border border-ivory/10 bg-graphite p-6">
          <div class="flex items-end justify-between">
            <div>
              <p class="text-xs uppercase tracking-[0.18em] text-faint">Price</p>
              <p class="price-aed font-display text-[2.4rem] font-bold leading-none text-gold">{fmtAED(car.priceAED)}</p>
            </div>
            {car.monthlyAED > 0 && (
              <p class="price-aed text-right text-xs text-faint">or from<br /><span class="text-sm text-ivory/80">{fmtAED(car.monthlyAED)} / mo</span></p>
            )}
          </div>
          <p class="mt-3 text-xs text-faint">Price includes VAT. Finance &amp; insurance available.</p>
          <div class="mt-5 flex flex-col gap-2.5">
            <a href={`${contact.whatsapp}?text=${waText}`} target="_blank" rel="noopener" class="btn-gold py-3.5"><MessageCircle class="h-4 w-4" /> Enquire on WhatsApp</a>
            <div class="grid grid-cols-2 gap-2.5">
              <a href={contact.phonePrimaryHref} class="btn-outline py-3"><Phone class="h-4 w-4" /> Call</a>
              <a href="/sell-your-car" class="btn-outline py-3"><Tag class="h-4 w-4" /> Trade-in</a>
            </div>
          </div>
        </div>

        <!-- specs -->
        <div class="mt-6 grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-ivory/10 bg-ivory/10 sm:grid-cols-3">
          {specRows.map((s) => (
            <div class="bg-graphite p-4">
              <s.icon class="h-5 w-5 text-gold/80" />
              <p class="mt-2 text-[0.7rem] uppercase tracking-wide text-faint">{s.label}</p>
              <p class="text-sm font-medium text-ivory">{s.value}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Description -->
    {(lead || bullets.length > 0) && (
      <section class="lux-wide pb-10">
        <div class="rounded-2xl border border-ivory/[0.08] bg-coal p-7 lg:p-10">
          <h2 class="font-display text-xl font-semibold text-ivory">About this {car.make}</h2>
          {lead && <p class="mt-4 max-w-3xl text-[0.98rem] leading-relaxed text-mist">{lead}</p>}
          {bullets.length > 0 && (
            <ul class="mt-6 grid grid-cols-1 gap-x-8 gap-y-2.5 sm:grid-cols-2">
              {bullets.map((b) => (
                <li class="flex gap-2.5 text-sm text-ivory/80"><span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-gold/70"></span>{b}</li>
              ))}
            </ul>
          )}
          <p class="mt-7 text-xs text-faint">Vehicle details supplied by Blackline Motor Company. Specification confirmed on viewing. <a href="/contact-us" class="text-gold/80 underline underline-offset-2 hover:text-gold">Contact us</a> for finance, warranty and service-contract options.</p>
        </div>
      </section>
    )}

    <!-- Similar — MOBILE: one car per row -->
    {sims.length > 0 && (
      <section class="border-t border-ivory/[0.08] bg-coal py-16 lg:py-20">
        <div class="lux-wide">
          <div class="flex items-end justify-between">
            <h2 class="display-3 text-ivory">Similar vehicles</h2>
            <a href="/our-cars" class="link-arrow">All cars <ArrowRight class="h-4 w-4" /></a>
          </div>
          <div class="mt-8 grid grid-cols-1 gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
            {sims.map((c) => <CarCard car={c} />)}
          </div>
        </div>
      </section>
    )}
  </div>
</Layout>

<script>
  const main = document.querySelector('[data-main]') as HTMLImageElement | null;
  const thumbs = Array.from(document.querySelectorAll('[data-thumb]')) as HTMLElement[];
  thumbs.forEach((t) => t.addEventListener('click', () => {
    if (!main) return;
    main.src = t.dataset.thumb || main.src;
    thumbs.forEach((x) => { x.classList.remove('border-gold/60'); x.classList.add('border-ivory/10'); });
    t.classList.add('border-gold/60'); t.classList.remove('border-ivory/10');
  }));
</script>
